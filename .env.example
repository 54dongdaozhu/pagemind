DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional embedding settings. Leave EMBEDDING_API_KEY empty to fall back to keyword search.
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small

# PostgreSQL settings used by Docker Compose.
POSTGRES_DB=pagemind
POSTGRES_USER=pagemind
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg2://pagemind:change-me@localhost:5432/pagemind

# Production HTTP port exposed by the nginx frontend container.
FRONTEND_PORT=80

# CORS origins accepted by the backend. For same-origin nginx deployments, http://localhost is enough.
ALLOWED_ORIGINS=http://localhost

# Keep this at 1 while using the bundled local ChromaDB storage.
UVICORN_WORKERS=1
